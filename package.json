{
  "name": "vaultrecall-mcp",
  "version": "1.0.0",
  "description": "Local MCP server that turns an Obsidian vault into a semantic second brain for Claude: keyword + meaning-based search, safe read/write, tags, and an incremental embedding index. Runs 100% locally, no API keys, no data leaves your machine.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin",
    "!dist/**/*.test.js"
  ],
  "bin": {
    "vaultrecall-mcp": "bin/cli.cjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "pretest": "tsc",
    "test": "node --test dist/services/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "gray-matter": "^4.0.3",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.4",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
